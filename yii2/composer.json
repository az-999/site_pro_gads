{
    "name": "sitepro/gads-platform",
    "description": "Site.pro keyword automation platform",
    "type": "project",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "yiisoft/yii2": "~2.0.49",
        "yiisoft/yii2-bootstrap5": "~2.0.4"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        },
        "process-timeout": 1800
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    }
}
